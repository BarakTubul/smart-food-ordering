# Select one: dev, staging, prod
APP_ENV=dev

APP_NAME=Smart Food Ordering Platform — Ordering & FAQ Assistant
API_PREFIX=/api/v1

# PostgreSQL default
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/customer_service

# Use a strong secret in real environments
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173

AUTH_COOKIE_NAME=access_token

# LLM mode: mock or openai
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
INTENT_RULE_CONFIDENCE_THRESHOLD=0.75
INTENT_ESCALATION_CONFIDENCE_THRESHOLD=0.6
LLM_FAQ_SYNTHESIS_ENABLED=true
